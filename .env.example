# .env.example
# Copy this to .env and fill in your actual keys

# The base URL for the LLM API (Groq/OpenAI/HuggingFace)
API_BASE_URL=https://api.groq.com/openai/v1

# The model identifier to use for inference
MODEL_NAME=llama-3.1-8b-instant

# Your API token (Required). In your HF Space, set this as a SECRET.
HF_TOKEN=your_token_here
